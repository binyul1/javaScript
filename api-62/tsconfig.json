{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2020",
    "types": ["node"],
    "lib": ["ES2020"],
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "./dist"]
}
